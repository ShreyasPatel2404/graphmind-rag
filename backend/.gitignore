# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-wheel-metadata/

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Uploads (user data — never commit) ──────────────────────────────────────
backend/uploads/

# ─── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.npm/
.pnpm-store/

# ─── Vite ─────────────────────────────────────────────────────────────────────
frontend/.vite/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Test / Coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage/
.nyc_output/

# ─── Alembic (keep versions, ignore runtime) ──────────────────────────────────
alembic/versions/*.pyc